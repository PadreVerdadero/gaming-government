{
  "name": "gaming-government",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n web,chamber -c cyan,magenta \"next dev\" \"tsx server/index.ts\"",
    "dev:web": "next dev",
    "dev:chamber": "tsx server/index.ts",
    "build": "next build",
    "start": "tsx server/prod.ts",
    "start:split": "concurrently -k -n web,chamber -c cyan,magenta \"next start\" \"tsx server/index.ts\"",
    "lint": "eslint"
  },
  "dependencies": {
    "nanoid": "^6.0.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.23.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.43",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  }
}
